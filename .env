# 应用配置
APP_NAME=FinalRAG
APP_VERSION=0.1.0
DEBUG=true

# API配置
API_HOST=0.0.0.0
API_PORT=8000

# NebulaGraph配置
NEBULA_HOST=192.168.10.10
NEBULA_PORT=30369
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=finalrag

# Milvus配置
MILVUS_HOST=192.168.10.10
MILVUS_PORT=30493

# 文档解析配置
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# 向量嵌入配置
EMBEDDING_SERVICE_URL=http://10.12.1.101:30082
EMBEDDING_BATCH_SIZE=32

# MinerU API 配置
MINERU_API_URL=http://10.12.1.101:30082

# 概念图谱配置
CONCEPT_GRAPH_MAX_EDGES_PER_NODE=20

# LLM配置 - 用于最终答案合成（对话质量要求高，用 DeepSeek）
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-b5da97ea05b44078afacd4371f075963
LLM_MODEL=deepseek-chat

# 摘要模型配置 - Section Summary / Community Summary / 实体抽取
# 使用本地部署的 qwen3.5-9b（103服务器）
SUMMARY_API_URL=http://10.12.1.103:30087/v1/chat/completions
SUMMARY_API_KEY=
SUMMARY_MODEL=/data/models/llm/Qwen3.5-9B

# 视觉模型配置 (qwen2.5-vl-7b) - 用于图片识别
VISION_API_URL=https://new-api-dev.10rig.com:8443/v1/chat/completions
VISION_API_KEY=sk-hdfLKnO9doMD7rIyyhGpMQGXonkARSa9R3gLmj4ytgHhuKTi
VISION_MODEL=qwen2.5-vl-7b

# 数据库重置配置（危险！仅开发环境使用）
# 启动时清空 NebulaGraph 图谱数据（改为 false，通过页面"清空数据库"按钮手动触发）
RESET_GRAPH_DB=false
# 启动时清空 Milvus 向量数据库数据
RESET_VECTOR_DB=false

# 功能模块开关 (可插拔)
# 图片实体提取 - 从图片中提取实体和关系
ENABLE_IMAGE_ENTITY_EXTRACTION=true
# 概念图谱 - 构建文档概念图谱
ENABLE_CONCEPT_GRAPH=true
# 异步嵌入 - 后台异步生成向量嵌入
ENABLE_ASYNC_EMBEDDING=true
# 摘要生成 - Section Summary / Community Summary
ENABLE_SUMMARY=true
